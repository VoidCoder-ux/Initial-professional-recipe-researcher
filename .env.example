OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Hazir saglayicilar: Bos birakirsan uygulama anahtarsiz DuckDuckGo aramasina duser.
TAVILY_API_KEY=
SERPER_API_KEY=
# Serbest arama API sağlayıcısı: SEARCH_API_URL doluysa Tavily/Serper yerine bu kullanılır.
# Örnek GET:
# SEARCH_API_URL=https://example.com/search?q={{queryUrl}}&limit={{maxResults}}
# SEARCH_API_METHOD=GET
#
# Örnek POST:
# SEARCH_API_URL=https://example.com/search
# SEARCH_API_METHOD=POST
# SEARCH_API_KEY=herhangi-bir-arama-api-key
# SEARCH_API_KEY_HEADER=Authorization
# SEARCH_API_KEY_PREFIX=Bearer 
# SEARCH_API_HEADERS={"Accept":"application/json"}
# SEARCH_API_BODY={"query":"{{query}}","limit":{{maxResults}}}
# SEARCH_API_RESULTS_PATH=results
# SEARCH_API_TITLE_PATH=title
# SEARCH_API_URL_PATH=url
# SEARCH_API_SNIPPET_PATH=snippet
SEARCH_API_URL=
SEARCH_API_METHOD=POST
SEARCH_API_KEY=
SEARCH_API_KEY_HEADER=Authorization
SEARCH_API_KEY_PREFIX=Bearer 
SEARCH_API_HEADERS=
SEARCH_API_BODY=
SEARCH_API_RESULTS_PATH=results
SEARCH_API_TITLE_PATH=title
SEARCH_API_URL_PATH=url
SEARCH_API_SNIPPET_PATH=content

PORT=8787
